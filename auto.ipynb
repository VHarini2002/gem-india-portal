   "source": [
    "import pyautogui\n",
    "import time\n",
    "\n",
    "while True:\n",
    "    pyautogui.press('shift')  # presses Shift key\n",
    "    print(\"Key pressed\")\n",
    "    time.sleep(120)  # wait for 2 minutes (120 seconds)"
   ]
  },
